## SS 5. Search/Browse Posts

Navigate to Substack search or explore page, wait 3s:

Extraction uses link-based approach: `a[href*="/p/"]` → walk up to container. No `article` or class-based selectors (Pencraft framework).

```javascript
browser.act({
  kind: "evaluate",
  fn: `() => {
    function isRecent(timeStr) {
      if (!timeStr) return false;
      if (/\\d{4}/.test(timeStr) && !/2026/.test(timeStr)) return false;
      if (/\\d+\\s*(d|h|min|sec|hr)/.test(timeStr)) {
        var days = timeStr.match(/(\\d+)\\s*d/);
        if (days && parseInt(days[1]) > 14) return false;
        return true;
      }
      var m = timeStr.match(/(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)\\s+(\\d+)/);
      if (m) {
        var months = {Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11};
        var d = new Date(new Date().getFullYear(), months[m[1]], parseInt(m[2]));
        return (Date.now() - d.getTime()) / 86400000 <= 14;
      }
      return true; // If can't parse, include it
    }
    // Link-based extraction: find post links, walk up to container for metadata
    var postLinks = Array.from(document.querySelectorAll('a[href*="/p/"]'));
    var seen = new Set();
    var results = [];
    for (var link of postLinks) {
      var url = link.href.split('?')[0];
      if (seen.has(url)) continue;
      seen.add(url);
      // Walk up to find the containing card (up to 8 levels)
      var container = link;
      for (var i = 0; i < 8; i++) {
        if (container.parentElement) container = container.parentElement;
        // Stop at a div that contains the full card (has author link + date text)
        if (container.querySelector && container.querySelector('a[href*="/@"]')) break;
      }
      var text = container.innerText || '';
      var lines = text.split('\\n').filter(l => l.trim());
      // Title: link text if substantial, otherwise first long line
      // Link text may contain "Publication\nTitle" - take last line as title
      var rawTitle = link.innerText.trim();
      var titleLines = rawTitle.split('\\n').filter(l => l.trim());
      var title = titleLines.length > 1 ? titleLines[titleLines.length - 1] : rawTitle;
      if (title.length < 10) title = lines.find(l => l.length > 15 && l.length < 200) || lines[0] || '';
      // Author: first non-empty a[href*="/@"] within container
      var authorEl = container.querySelector ? Array.from(container.querySelectorAll('a[href*="/@"]')).find(a => a.innerText.trim().length > 0) : null;
      var author = authorEl ? authorEl.innerText.trim() : '';
      // Date: look for relative time or month-day patterns
      var timeLine = lines.find(l => /\\d+\\s*(d|h|min|hr)\\s*(ago)?/.test(l) || /^(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)\\s+\\d/.test(l)) || '';
      // Likes: number before "like" text or standalone numbers near like icons
      var likeCount = (text.match(/(\\d+)\\s*like/i) || [])[1] || '0';
      // Also check for standalone numbers (Substack shows counts as plain numbers)
      if (likeCount === '0') {
        var nums = text.match(/^(\\d+)$/m);
        if (nums) likeCount = nums[1];
      }
      var isCustomDomain = !url.includes('.substack.com/p/');
      results.push({
        url, title: title.slice(0, 80), author: author.slice(0, 30), date: timeLine,
        likes: parseInt(likeCount) || 0, isCustomDomain: isCustomDomain
      });
      if (results.length >= 10) break;
    }
    return results.filter(a => a.url && isRecent(a.date) && !a.isCustomDomain);
  }`,
  profile: "{{browser_profile}}"
})
```

After extraction: grep pre-check against `commented_posts.txt` before navigating.

