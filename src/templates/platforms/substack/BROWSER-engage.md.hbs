## SS 7. Notes Engagement

Navigate to `https://substack.com/notes`, wait 3s:

```javascript
browser.act({
  kind: "evaluate",
  fn: `() => {
    var notes = document.querySelectorAll('[class*="note"], article');
    return Array.from(notes).slice(0, 10).map(note => {
      var text = note.innerText;
      var author = (note.querySelector('a[href*="/@"]') || {}).innerText || '';
      var link = note.querySelector('a[href*="/note/"], a[href*="/p/"]');
      var url = link ? link.href.split('?')[0] : '';
      return {
        url, author: author.slice(0, 30),
        preview: text.slice(0, 200)
      };
    }).filter(n => n.url || n.preview.length > 20);
  }`,
  profile: "{{browser_profile}}"
})
```

## SS 8. Batch Like Notes (from feed page)

🚨 Notes feed Like buttons do NOT change `aria-label` to "Unlike" after clicking. Verify by checking count increase.

```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    await new Promise(r => setTimeout(r, 1000));
    var btns = Array.from(document.querySelectorAll('button'));
    var likeBtns = btns.filter(b => {
      var label = (b.getAttribute('aria-label') || '').toLowerCase();
      return label === 'like' && b.getBoundingClientRect().width > 0;
    });
    var liked = [];
    var max = ${maxLikes};
    for (var i = 0; i < likeBtns.length && liked.length < max; i++) {
      var b = likeBtns[i];
      var prevCount = parseInt(b.innerText.trim()) || 0;
      b.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true }));
      await new Promise(r => setTimeout(r, 500));
      var newCount = parseInt(b.innerText.trim()) || 0;
      if (newCount > prevCount) {
        liked.push({ idx: i, prev: prevCount, now: newCount });
      } else {
        // Count didn't increase or decreased — was already liked, click again to undo the unlike
        b.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true }));
        await new Promise(r => setTimeout(r, 300));
      }
    }
    return { liked: liked };
  }`,
  profile: "{{browser_profile}}"
})
```
