## SS 4. Like Post

Navigate to post, wait 2s.

Like buttons: `aria-label="Like (N)"` on posts, text "Like" on notes. "Unlike" = already liked.

```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    await new Promise(r => setTimeout(r, 2000));
    var btns = Array.from(document.querySelectorAll('button'));
    // Primary: aria-label starts with "Like"
    var likeBtn = btns.find(b => {
      var label = (b.getAttribute('aria-label') || '').toLowerCase();
      return label.startsWith('like');
    });
    // Fallback: button text exactly "Like" (notes feed)
    if (!likeBtn) {
      likeBtn = btns.find(b => b.innerText.trim() === 'Like');
    }
    if (!likeBtn) return { error: 'like button not found' };
    // Check if already liked (label changes to "Unlike")
    var label = (likeBtn.getAttribute('aria-label') || '').toLowerCase();
    if (label.startsWith('unlike')) return { alreadyLiked: true };
    likeBtn.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true }));
    await new Promise(r => setTimeout(r, 1000));
    var newLabel = likeBtn.getAttribute('aria-label') || '';
    return { liked: true, newLabel: newLabel };
  }`,
  profile: "{{browser_profile}}"
})
```

