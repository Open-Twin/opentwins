## SS 2. Read Post Content

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { var h1 = document.querySelector('h1.post-title') || Array.from(document.querySelectorAll('h1')).find(h => h.className.includes('post-title') || h.className.includes('title')) || document.querySelector('h1:nth-of-type(2)') || document.querySelector('h1'); var article = document.querySelector('.body.markup') || document.querySelector('article') || document.querySelector('.post-content'); var content = article ? article.innerText : document.body.innerText; var lines = content.split(String.fromCharCode(10)).filter(l => l.trim()); var contentStart = lines.findIndex(l => l.length > 80); var body = contentStart >= 0 ? lines.slice(contentStart).join('\\n') : content; var author = Array.from(document.querySelectorAll('a[href*=\"/@\"]')).find(a => a.innerText.trim().length > 0); return { title: h1 ? h1.innerText : '', author: author ? author.innerText.trim() : '', content: body.slice(0, 1200) }; }"}
ENDJSON
```

