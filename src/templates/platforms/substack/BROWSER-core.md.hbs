## SS 2. Read Post Content

```javascript
browser.act({
  kind: "evaluate",
  fn: `() => {
    const h1 = document.querySelector('h1.post-title') || Array.from(document.querySelectorAll('h1')).find(h => h.className.includes('post-title') || h.className.includes('title')) || document.querySelector('h1:nth-of-type(2)') || document.querySelector('h1');
    const article = document.querySelector('.body.markup') || document.querySelector('article') || document.querySelector('.post-content');
    const content = article ? article.innerText : document.body.innerText;
    const lines = content.split('\\\\n').filter(l => l.trim());
    const contentStart = lines.findIndex(l => l.length > 80);
    const body = contentStart >= 0 ? lines.slice(contentStart).join('\\\\n') : content;
    const author = Array.from(document.querySelectorAll('a[href*="/@"]')).find(a => a.innerText.trim().length > 0);
    return {
      title: h1 ? h1.innerText : '',
      author: author ? author.innerText.trim() : '',
      content: body.slice(0, 1200)
    };
  }`,
  profile: "{{browser_profile}}"
})
```

