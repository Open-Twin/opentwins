## SS 2. Add Recommendation (Search + Reason + Submit)

🚨 **Verified 2026-03-28:** The "Add recommendation" button opens an inline form with:
- `input[type="search"]` — headlessui combobox, placeholder "Search for a person or publication..."
- `textarea` — placeholder "Tell your subscribers why they'll love this Substack"
- `button` "Add recommendation" — submit

**Step 0 — Navigate to recommendations dashboard:**
```
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/navigate -H 'Content-Type: application/json' -d '{"url":"https://{{handle}}.substack.com/publish/recommendations"}' 2>&1
```

**Step 1 — Open the form:**
```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    await new Promise(r => setTimeout(r, 2000));
    var btns = Array.from(document.querySelectorAll('button'));
    var addBtn = btns.find(b => b.innerText.includes('Add recommendation'));
    if (!addBtn) return { error: 'no Add recommendation button' };
    addBtn.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true }));
    await new Promise(r => setTimeout(r, 1500));
    var input = document.querySelector('input[type=search]');
    var textarea = document.querySelector('textarea');
    return { formOpen: !!(input && textarea) };
  }`,
  profile: "{{browser_profile}}"
})
```

**Step 2 — Search for publication and select from autocomplete:**
```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    await new Promise(r => setTimeout(r, 500));
    var input = document.querySelector('input[type=search]');
    if (!input) return { error: 'no search input' };
    input.focus();
    input.value = ${JSON.stringify(publicationName)};
    input.dispatchEvent(new Event('input', { bubbles: true }));
    input.dispatchEvent(new Event('change', { bubbles: true }));
    await new Promise(r => setTimeout(r, 2000));
    // Find matching option in autocomplete
    var options = Array.from(document.querySelectorAll('[role=option]'));
    var target = options.find(o => {
      var t = o.innerText.toLowerCase();
      return t.includes(${JSON.stringify(publicationName.toLowerCase())});
    });
    if (!target) return { error: 'publication not found in autocomplete', options: options.map(o => o.innerText.slice(0, 60)) };
    target.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true }));
    await new Promise(r => setTimeout(r, 1000));
    return { selected: true, value: input.value };
  }`,
  profile: "{{browser_profile}}"
})
```

**Step 3 — Fill reason and submit:**

🚨 **Reason guidelines:** Write from your PM perspective. Explain WHY this publication matters for your audience (PMs navigating AI adoption). Keep it 1-2 sentences, specific, not generic praise. Mention what makes them unique.

```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    await new Promise(r => setTimeout(r, 500));
    var textarea = document.querySelector('textarea');
    if (!textarea) return { error: 'no reason textarea' };
    textarea.focus();
    textarea.value = ${JSON.stringify(reasonText)};
    textarea.dispatchEvent(new Event('input', { bubbles: true }));
    textarea.dispatchEvent(new Event('change', { bubbles: true }));
    await new Promise(r => setTimeout(r, 500));
    // Find submit button - last "Add recommendation" button on page
    var btns = Array.from(document.querySelectorAll('button'));
    var submitBtns = btns.filter(b => b.innerText.trim() === 'Add recommendation');
    var submitBtn = submitBtns[submitBtns.length - 1];
    if (!submitBtn) return { error: 'no submit button' };
    submitBtn.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true }));
    await new Promise(r => setTimeout(r, 3000));
    // Verify - check for "Recommendation added" or the publication in outgoing list
    var pageText = document.body.innerText;
    var verified = pageText.includes('Recommendation added') || pageText.includes('Active');
    return { submitted: true, verified: verified };
  }`,
  profile: "{{browser_profile}}"
})
```

