## S 2. Find and Click First Unreplied Post

**Requires `allowedIds`** — array of post IDs from grep pre-check (step 3b). Inline as JSON array in template literal.

```javascript
// allowedIds = ["DUqc1LaCtOk", "ABC123"] — from grep pre-check output
browser.act({
  kind: "evaluate",
  fn: `() => {
    const allowedIds = ${JSON.stringify(allowedIds)};
    const links = Array.from(document.querySelectorAll('a[href*="/post/"]'));

    for (const link of links) {
      const postId = link.href.match(/\\/post\\/([^/?]+)/)?.[1];
      if (!postId || !allowedIds.includes(postId)) continue;

      let container = link.parentElement.parentElement.parentElement;
      const lines = container.innerText.split('\\n').filter(l => l.trim());
      const author = lines[0] || '';

      if (author === '{{handle_slug}}') continue;

      const commentIcon = container.querySelector('svg[aria-label="Reply"]');
      const iconParent = commentIcon ? commentIcon.parentElement : null;
      const iconGrandParent = iconParent ? iconParent.parentElement : null;
      const nearbyText = iconGrandParent ? iconGrandParent.innerText.trim() : '';
      if (/^\\d+$/.test(nearbyText)) continue;

      let searchContainer = link;
      for (let i = 0; i < 10; i++) {
        searchContainer = searchContainer.parentElement;
        if (!searchContainer) break;

        const replyIcon = searchContainer.querySelector('svg[aria-label="Reply"]');
        if (replyIcon) {
          const button = replyIcon.closest('div[role="button"]') || replyIcon.parentElement?.parentElement;
          if (button) {
            button.click();
            return { clicked: true, url: link.href, author: author, postId: postId };
          }
        }
      }
    }

    return { clicked: false, error: 'no_unreplied_posts' };
  }`,
  profile: "{{browser_profile}}"
})
```

