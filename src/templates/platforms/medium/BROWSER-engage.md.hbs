## § 5. Search Articles

NEVER snapshot search pages. Auto-filters: only `/@author/` URLs, only ≤14 days old.

```javascript
browser.act({
  kind: "evaluate",
  fn: `() => {
    function parseCount(s) {
      if (!s) return 0;
      s = s.trim().replace(/,/g, '');
      if (/k$/i.test(s)) return Math.round(parseFloat(s) * 1000);
      if (/m$/i.test(s)) return Math.round(parseFloat(s) * 1000000);
      return parseInt(s) || 0;
    }
    function isRecent(timeStr) {
      if (!timeStr) return false;
      // Medium shows year only for old articles — reject any date with a 4-digit year
      if (/\\d{4}/.test(timeStr)) return false;
      if (/\\d+\\s*(d|h|min|sec)/.test(timeStr)) {
        const days = timeStr.match(/(\\d+)\\s*d/);
        if (days && parseInt(days[1]) > 14) return false;
        return true;
      }
      const m = timeStr.match(/^(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)\\s+(\\d+)/);
      if (m) {
        const months = {Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11};
        const d = new Date(new Date().getFullYear(), months[m[1]], parseInt(m[2]));
        return (Date.now() - d.getTime()) / 86400000 <= 14;
      }
      return false;
    }
    const articles = document.querySelectorAll('article');
    return Array.from(articles).slice(0, 10).map(article => {
      const text = article.innerText;
      const lines = text.split('\\n').filter(l => l.trim());
      const title = article.querySelector('h2, h3')?.innerText || '';
      const byIdx = lines.findIndex(l => l === 'by');
      const author = byIdx >= 0 ? (lines[byIdx + 1] || '') : lines[0] || '';
      const timeLine = lines.find(l => /\\d+\\s*(d|h|min)\\s*ago/.test(l) || /^(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)\\s+\\d/.test(l)) || '';
      const allLinks = Array.from(article.querySelectorAll('a'));
      const articleLink = allLinks.find(a => title.length > 10 && a.innerText.includes(title.slice(0, 20)));
      const url = (articleLink?.href || '').split('?')[0];
      const statsLink = allLinks.find(a => /^[\\dKkMm.,]+\\n[\\dKkMm.,]+$/.test(a.innerText.trim()));
      const statsText = statsLink ? statsLink.innerText.trim().split('\\n') : [];
      const fallbackNums = lines.filter(l => /^[\\d,.]+[KkMm]?$/.test(l));
      return {
        url, title: title.slice(0, 80), author: author.slice(0, 30), date: timeLine,
        claps: parseCount(statsText[0] || fallbackNums[0] || '0'),
        responses: parseCount(statsText[1] || fallbackNums[1] || '0')
      };
    }).filter(a => a.url && /medium\\.com\\/((@[^/]+)|([^@][^/]+))\\/[^/]+-[a-f0-9]{8,}/.test(a.url) && isRecent(a.date));
  }`,
  profile: "{{browser_profile}}"
})
```

🚨 **URL filter accepts BOTH author URLs (`/@author/slug`) AND publication URLs (`/pub-name/slug-hash`).** Publication URLs may redirect to custom domains (e.g. `levelup.gitconnected.com`) — this is normal and works fine. If a redirect causes SSL error → skip that article immediately.

After extraction: grep pre-check against `commented_posts.txt` before navigating. Prefer articles with responses > 0.

