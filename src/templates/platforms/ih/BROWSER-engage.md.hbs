## S 2. Extract Feed Posts

```javascript
browser.act({
  kind: "evaluate",
  fn: `() => {
    return new Promise(function(resolve) {
      setTimeout(function() {
        var b = document.querySelector('#onetrust-accept-btn-handler');
        if (b) b.click();
        var posts = Array.from(document.querySelectorAll('.story.homepage-post'));
        resolve({
          count: posts.length,
          items: posts.slice(0, 10).map(function(post) {
            var link = post.querySelector('a[href*="/post/"]') || post.querySelector('a[href*="/product/"]');
            var lines = post.innerText.split('\\n').filter(function(l) { return l.trim(); });
            var numbers = lines.filter(function(l) { return /^\d+$/.test(l.trim()); });
            var lastNumbers = numbers.slice(-2);
            return {
              url: link ? link.href : '',
              title: post.querySelector('.story__title') ? post.querySelector('.story__title').innerText.slice(0, 80) : '',
              upvotes: lastNumbers[0] ? parseInt(lastNumbers[0]) : 0,
              comments: lastNumbers[1] ? parseInt(lastNumbers[1]) : 0
            };
          }).filter(function(p) { return p.url; })
        });
      }, 3000);
    });
  }`,
  profile: "{{browser_profile}}"
})
```

## S 3. Extract Post Content (after navigating to post page)

Returns the post title and body text. Run this BEFORE upvoting or typing a comment. Use the returned `title` and `body` to inform your comment — your comment MUST directly address this specific post's topic.

```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    await new Promise(r => setTimeout(r, 3000));
    var titleEl = document.querySelector('h1') || document.querySelector('.story__title');
    var title = titleEl ? titleEl.innerText.trim() : '';
    var bodyEl = document.querySelector('.content') || document.querySelector('article') || document.querySelector('.post-body');
    var body = bodyEl ? bodyEl.innerText.trim().slice(0, 500) : '';
    return { title, body };
  }`,
  profile: "{{browser_profile}}"
})
```

