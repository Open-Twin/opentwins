## S 5. Write Top-Level Comment (3 evaluates total)

Comment box already visible on post page (no reply click needed).

⚠️ **Some posts use plain `<textarea>` instead of TipTap.** If `.tiptap.ProseMirror` not found, fall back to:
```javascript
var ta = commentBox.querySelector('textarea');
if (ta) { ta.focus(); ta.value = commentText; ta.dispatchEvent(new Event('input', {bubbles:true})); }
```

🚨 **Two-step pattern** — TipTap needs an event loop tick before submit button enables.
- ❌ **NEVER** combine text insertion + submit check in ONE evaluate — `submitBtn.disabled` will be `true`
- ❌ **NEVER** add `.click()` on submit in the same evaluate as `execCommand('insertText')`
- ✅ Step 1 = insert text ONLY. Step 2 = wait + submit. Step 3 = wait + verify.

```javascript
// Step 1 of 3: Insert text ONLY (no submit attempt!)
browser.act({
  kind: "evaluate",
  fn: `() => {
    var commentText = '${commentText.replace(/'/g, "\\'")}';
    var commentBox = document.querySelector('.comment-box');
    if (!commentBox) return { error: 'comment_box_not_found' };
    var editor = commentBox.querySelector('.tiptap.ProseMirror');
    if (!editor) return { error: 'editor_not_found' };
    editor.focus();
    document.execCommand('selectAll', false, null);
    document.execCommand('delete', false, null);
    document.execCommand('insertText', false, commentText);
    editor.dispatchEvent(new InputEvent('input', { data: commentText, inputType: 'insertText', bubbles: true }));
    return { inserted: true, textLen: editor.innerText.length };
  }`,
  profile: "{{browser_profile}}"
})
```

```javascript
// Step 2 of 3: Wait 500ms for TipTap state propagation, then submit
browser.act({
  kind: "evaluate",
  fn: `() => {
    return new Promise(function(resolve) {
      setTimeout(function() {
        var commentBox = document.querySelector('.comment-box');
        if (!commentBox) return resolve({ error: 'comment_box_not_found' });
        var submitBtn = commentBox.querySelector('.comment-box__save-button');
        if (!submitBtn) return resolve({ error: 'submit_button_not_found' });
        if (submitBtn.disabled) return resolve({ error: 'submit_still_disabled' });
        submitBtn.click();
        resolve({ success: true });
      }, 500);
    });
  }`,
  profile: "{{browser_profile}}"
})
```

```javascript
// Step 3 of 3: Wait 3s, verify OUR comment posted
// 🚨 Use "{{handle}}" (username shown on page), NOT "{{name}}" (full name — NOT rendered)
browser.act({
  kind: "evaluate",
  fn: `() => {
    return new Promise(function(resolve) {
      setTimeout(function() {
        var comments = document.querySelectorAll('.comment');
        var ourCount = 0;
        comments.forEach(function(c) {
          if (c.innerText.indexOf('{{handle}}') >= 0) ourCount++;
        });
        resolve({ verified: ourCount > 0, commentCount: comments.length, ourComments: ourCount });
      }, 3000);
    });
  }`,
  profile: "{{browser_profile}}"
})
```

🚨 **Retry rules (STRICT — do NOT deviate):**
- If `verified: true`: success, proceed to tracking.
- If `ourComments > 1`: duplicate was posted — do NOT retry, log `Type="Error:DuplicateComment"`, proceed to tracking.
- If `verified: false` AND `ourComments == 0` AND `commentCount` UNCHANGED from before step 1: retry step 2 ONLY (click submit). **NEVER re-insert text.** If retry also fails: HEARTBEAT_BLOCKED.
- If `verified: false` AND `commentCount` INCREASED: comment likely posted — treat as success, proceed to tracking.
- ❌ **NEVER re-insert text and re-submit as a "fix"** — this is the #1 cause of duplicate comments.

## S 6. Upvote Post (single evaluate — click + wait + verify)

```javascript
// 1 evaluate: upvote + 1s wait + verify (NOT 3 separate steps)
browser.act({
  kind: "evaluate",
  fn: `() => {
    var postUpvote = document.querySelector('.post-liker');
    if (!postUpvote) return { error: 'upvote_button_not_found' };
    if (postUpvote.classList.contains('post-liker--liked')) return { skipped: true, reason: 'already_upvoted' };
    postUpvote.click();
    return new Promise(function(resolve) {
      setTimeout(function() {
        var verified = document.querySelector('.post-liker--liked') !== null;
        resolve({ success: true, verified: verified });
      }, 1000);
    });
  }`,
  profile: "{{browser_profile}}"
})
```
