## S 2. Extract Feed Posts

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { await new Promise(r => setTimeout(r, 3000)); var b = document.querySelector('#onetrust-accept-btn-handler'); if (b) b.click(); var posts = Array.from(document.querySelectorAll('.story.homepage-post')); return { count: posts.length, items: posts.slice(0, 10).map(function(post) { var link = post.querySelector('a[href*=\"/post/\"]') || post.querySelector('a[href*=\"/product/\"]'); var lines = post.innerText.split(String.fromCharCode(10)).filter(function(l) { return l.trim(); }); var numbers = lines.filter(function(l) { return /^\\d+$/.test(l.trim()); }); var lastNumbers = numbers.slice(-2); return { url: link ? link.href : '', title: post.querySelector('.story__title') ? post.querySelector('.story__title').innerText.slice(0, 80) : '', upvotes: lastNumbers[0] ? parseInt(lastNumbers[0]) : 0, comments: lastNumbers[1] ? parseInt(lastNumbers[1]) : 0 }; }).filter(function(p) { return p.url; }) }; }"}
ENDJSON
```

## S 3. Extract Post Content (after navigating to post page)

Returns the post title and body text. Run this BEFORE upvoting or typing a comment. Use the returned `title` and `body` to inform your comment — your comment MUST directly address this specific post's topic.

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { await new Promise(r => setTimeout(r, 3000)); var titleEl = document.querySelector('.post-page__title') || document.querySelector('.product-update__title') || document.querySelector('.firestore-post__title') || document.querySelector('h1'); var title = titleEl ? titleEl.innerText.trim() : ''; var bodyEl = document.querySelector('.post-page__body') || document.querySelector('.firestore-post__main'); var body = bodyEl ? bodyEl.innerText.trim().slice(0, 500) : ''; if (!body) { var text = document.body.innerText; var lines = text.split(String.fromCharCode(10)).filter(function(l) { return l.trim().length > 50; }); body = lines.slice(0, 5).join(String.fromCharCode(10)).slice(0, 500); } return { title: title, body: body }; }"}
ENDJSON
```

