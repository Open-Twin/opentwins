## SS 4b. Comment on Pulse Article (Quill Editor)

🚨 **Pulse articles use QUILL editor, NOT TipTap.** `execCommand('insertText')` inserts text in the DOM but leaves Quill's internal Delta state EMPTY → submit is silently rejected. Must use Quill's API directly.

**Prerequisite:** Agent has already navigated to the Pulse article URL and confirmed the article loads (dedup/content-read step in HEARTBEAT.md).

### Step 1: Scroll to comments + open composer + insert via Quill API (ONE async evaluate)
```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    // Scroll to bottom to lazy-load comment section
    window.scrollTo(0, document.body.scrollHeight);
    await new Promise(r => setTimeout(r, 2500));

    // Focus the editor (Pulse renders a placeholder that becomes a Quill editor on click)
    var composer = document.querySelector('.ql-editor[contenteditable="true"]')
                 || document.querySelector('[class*="comments-comment-box"] [contenteditable="true"]')
                 || document.querySelector('.comments-comment-box__form [contenteditable="true"]');
    if (!composer) {
      // Try clicking the comment placeholder first
      var placeholder = document.querySelector('[class*="comments-comment-box__comment-input"]') || document.querySelector('button[aria-label*="Comment"]');
      if (placeholder) { placeholder.click(); await new Promise(r => setTimeout(r, 1500)); }
      composer = document.querySelector('.ql-editor[contenteditable="true"]') || document.querySelector('[class*="comments-comment-box"] [contenteditable="true"]');
    }
    if (!composer) return { error: 'no_quill_editor_found' };

    // Get the Quill instance via its container element
    // LinkedIn wraps Quill in .ql-container; Quill stores instance on the container element
    var qlContainer = composer.closest('.ql-container') || composer.parentElement;
    var quillInstance = null;

    // Method 1: Quill.find() (if Quill global is exposed)
    if (typeof window.Quill !== 'undefined' && window.Quill.find) {
      quillInstance = window.Quill.find(qlContainer);
    }
    // Method 2: walk DOM for __quill property set by Quill internals
    if (!quillInstance) {
      var probe = composer;
      while (probe && !quillInstance) {
        if (probe.__quill) quillInstance = probe.__quill;
        probe = probe.parentElement;
      }
    }

    var text = "${commentText.replace(/"/g, '\\"').replace(/\n/g, '\\n')}";

    if (quillInstance) {
      // PROPER way: Quill API updates both DOM and Delta state
      quillInstance.setText(text);
      // Place cursor at end and trigger text-change via a no-op edit
      quillInstance.setSelection(text.length, 0, 'user');
    } else {
      // Fallback: simulate typing via InputEvents which Quill listens to
      composer.focus();
      composer.innerHTML = '';
      // Fire beforeinput + input events that Quill's Delta binding will catch
      var inputEvent = new InputEvent('beforeinput', { bubbles: true, cancelable: true, inputType: 'insertText', data: text });
      composer.dispatchEvent(inputEvent);
      // If beforeinput wasn't canceled, insert via execCommand as last resort
      document.execCommand('insertText', false, text);
      composer.dispatchEvent(new Event('input', { bubbles: true }));
    }

    await new Promise(r => setTimeout(r, 800));

    var currentText = composer.innerText || composer.textContent || '';
    return {
      editorFound: true,
      quillInstanceUsed: !!quillInstance,
      textInserted: currentText.trim().length > 0,
      preview: currentText.slice(0, 80)
    };
  }`,
  profile: "{{browser_profile}}"
})
```

If `textInserted: false` → skip this target, log error with `Reason: quill_insertion_failed`. Do NOT attempt submit.

### Step 2: Submit + authoritative verify (ONE async evaluate)
🚨 **Pulse submit button uses `aria-label` starting with "Post comment on", NOT `data-view-name="comment-post"`.** Verified Apr 9, 2026 — data-view-name selector works for feed inline comments only. For Pulse, find the button inside the composer's form by aria-label prefix.

```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    // Find the submit button: lives inside composer form, identified by aria-label starting with "Post comment on"
    var composer = document.querySelector('.ql-editor[contenteditable="true"]');
    var form = composer ? composer.closest('form') : null;
    if (!form) return { error: 'no_form' };
    var btns = Array.from(form.querySelectorAll('button'));
    var submitBtn = btns.find(function(b) {
      var label = (b.getAttribute('aria-label') || '').toLowerCase();
      return label.indexOf('post comment on') === 0;
    });
    // Fallback: try data-view-name in case LinkedIn standardizes later
    if (!submitBtn) submitBtn = form.querySelector('button[data-view-name="comment-post"]');
    if (!submitBtn) return { error: 'no_submit_button', labels: btns.map(function(b) { return b.getAttribute('aria-label'); }) };
    if (submitBtn.disabled || submitBtn.getAttribute('aria-disabled') === 'true') {
      return { error: 'submit_disabled', reason: 'Quill Delta likely empty even though DOM has text' };
    }
    submitBtn.click();

    // Wait for submission + render into comment list
    await new Promise(r => setTimeout(r, 5000));

    // 🚨 AUTHORITATIVE VERIFY: find our comment in the Pulse comments list
    var snippet = "${commentText.slice(0, 35).replace(/"/g, '\\"')}";
    var ourLinks = Array.from(document.querySelectorAll('a[href*="/in/{{handle_slug}}"]'));
    var ourCommentFound = false;
    var foundWhere = '';
    for (var i = 0; i < ourLinks.length; i++) {
      if (ourLinks[i].href.includes('sidebar_menu') || ourLinks[i].href.includes('author')) continue;
      var parent = ourLinks[i].closest('article') || ourLinks[i].closest('[class*="comment-entity"]') || ourLinks[i].closest('[data-urn*="comment"]');
      if (!parent) parent = ourLinks[i].parentElement;
      for (var hops = 0; hops < 8 && parent; hops++) {
        if (parent.innerText && parent.innerText.indexOf(snippet) > -1 && !parent.querySelector('[role="textbox"]') && !parent.querySelector('.ql-editor')) {
          ourCommentFound = true;
          foundWhere = parent.tagName + '.' + (parent.className || '').slice(0, 40);
          break;
        }
        parent = parent.parentElement;
      }
      if (ourCommentFound) break;
    }

    // Also check editor cleared
    var editorAfter = document.querySelector('.ql-editor[contenteditable="true"]');
    var editorEmpty = !editorAfter || (editorAfter.innerText || '').trim().length === 0;

    return {
      submitted: true,
      editorEmpty: editorEmpty,
      ourCommentFound: ourCommentFound,
      foundWhere: foundWhere,
      verified: ourCommentFound
    };
  }`,
  profile: "{{browser_profile}}"
})
```

If `verified: false`: retry Step 1 + Step 2 ONCE. Still fails → do NOT log, do NOT increment counters, skip.

🚨 **Critical:** `verified` is ONLY true if `ourCommentFound` is true. Editor being empty is NOT proof — Quill can clear the DOM on submit rejection. The only authoritative signal is our comment appearing in the comment list.

## SS 6. Like Posts (Batch) + Verify (ONE async evaluate)

```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    var maxLikes = ${maxLikes};
    var buttons = document.querySelectorAll('button');
    var unliked = [];
    for (var i = 0; i < buttons.length; i++) {
      var label = buttons[i].getAttribute('aria-label');
      if (label === 'Reaction button state: no reaction') unliked.push(buttons[i]);
    }
    var liked = 0;
    for (var i = 0; i < Math.min(maxLikes, unliked.length); i++) {
      unliked[i].click();
      liked++;
    }
    // Embedded verify wait
    await new Promise(r => setTimeout(r, 2000));
    var verifyBtns = document.querySelectorAll('button');
    var likedCount = 0;
    for (var j = 0; j < verifyBtns.length; j++) {
      if (verifyBtns[j].getAttribute('aria-label') === 'Reaction button state: Like') likedCount++;
    }
    return { totalUnliked: unliked.length, attempted: liked, totalLikedAfter: likedCount };
  }`,
  profile: "{{browser_profile}}"
})
```

## SS 7. Article Publishing

### Brand Links (use when article mentions the brand)
| Resource | URL |
|----------|-----|
| LinkedIn | linkedin.com/in/{{handle_slug}} |
| GitHub | github.com/{{handle_slug}} |
| BRAND.md | See /BRAND.md for full positioning |

### Step 1: Set title
```javascript
browser.act({
  kind: "evaluate",
  fn: `() => {
    var ta = document.querySelector('textarea.article-editor-headline__textarea');
    if (!ta) return { success: false, reason: 'no-title-textarea' };
    var nativeSetter = Object.getOwnPropertyDescriptor(window.HTMLTextAreaElement.prototype, 'value').set;
    nativeSetter.call(ta, "${articleTitle.replace(/"/g, '\\"')}");
    ta.dispatchEvent(new Event('input', { bubbles: true }));
    ta.dispatchEvent(new Event('change', { bubbles: true }));
    return { success: true, value: ta.value };
  }`,
  profile: "{{browser_profile}}"
})
```
Title textarea has maxLength=150. Do NOT use `type` or `fill` actions - they fail on this element.

### Step 2: Set body content (wait 1s after title)
```javascript
// articleHTML = '<p>First paragraph...</p><p><strong>Section heading</strong></p><p>Content...</p>'
browser.act({
  kind: "evaluate",
  fn: `() => {
    var editor = document.querySelector('[role="textbox"][aria-label="Article editor content"]');
    if (!editor) return { success: false, reason: 'no-editor' };
    editor.innerHTML = \`${articleHTML}\`;
    editor.dispatchEvent(new Event('input', { bubbles: true }));
    return { success: true, length: editor.innerText.length };
  }`,
  profile: "{{browser_profile}}"
})
```

**Article body rules:**
- Use `<p>` for paragraphs, `<strong>` for section headings
- Include brand link as `<a href="https://linkedin.com/in/{{handle_slug}}">{{name}}</a>` or `<a href="https://github.com/{{handle_slug}}">open-source PM tools</a>` at least once in the article body
- Hashtags go in the share text (Step 4), NOT in article body
- Keep HTML under 8000 chars to avoid evaluate payload bloat

### Step 3: Click Next (wait 1s after body)
```javascript
browser.act({
  kind: "evaluate",
  fn: `() => {
    var buttons = document.querySelectorAll('button');
    for (var i = 0; i < buttons.length; i++) {
      if (buttons[i].innerText.trim() === 'Next') {
        buttons[i].click();
        return { clicked: true };
      }
    }
    return { clicked: false, reason: 'no-next-button' };
  }`,
  profile: "{{browser_profile}}"
})
```

### Step 4: Add share text with hashtags (wait 2s after Next for dialog)

The publish dialog has a Quill `.ql-editor` with placeholder "Tell your network what your article is about..."

```javascript
// shareText = "One-liner about article + 3-5 hashtags"
// Example: "47 meetings in one week taught me why meeting culture is broken - and what I built to fix it.\n\n#meetingculture #productivity #ai #buildinpublic #vibecoding"
browser.act({
  kind: "evaluate",
  fn: `() => {
    var editor = document.querySelector('.ql-editor[data-placeholder*="Tell your network"]');
    if (!editor) return { success: false, reason: 'no-share-editor' };
    editor.focus();
    var text = "${shareText.replace(/"/g, '\\"').replace(/\n/g, '\\n')}";
    editor.innerHTML = '<p>' + text.replace(/\\n/g, '</p><p>') + '</p>';
    editor.dispatchEvent(new Event('input', { bubbles: true }));
    editor.classList.remove('ql-blank');
    return { success: true, text: editor.innerText.slice(0, 100) };
  }`,
  profile: "{{browser_profile}}"
})
```

**Hashtag rules:** Pick 3-5 from queries.json `hashtags` array. Match article topic. Always include `#buildinpublic`.

### Step 5: Click Publish (wait 1s after share text)
```javascript
browser.act({
  kind: "evaluate",
  fn: `() => {
    var buttons = document.querySelectorAll('button');
    for (var i = 0; i < buttons.length; i++) {
      if (buttons[i].innerText.trim() === 'Publish' && !buttons[i].disabled) {
        buttons[i].click();
        return { clicked: true };
      }
    }
    return { clicked: false, reason: 'no-publish-button' };
  }`,
  profile: "{{browser_profile}}"
})
```

### Step 6: Verify (wait 5s after publish)
```javascript
browser.act({
  kind: "evaluate",
  fn: `() => {
    var url = window.location.href;
    return {
      published: url.indexOf('published=t') > -1 || url.indexOf('/pulse/') > -1,
      url: url,
      title: document.title
    };
  }`,
  profile: "{{browser_profile}}"
})
```

If NOT published (still on edit page): wait 3s, check URL again. If still not published after 2 attempts: log error, do NOT mark task done.
