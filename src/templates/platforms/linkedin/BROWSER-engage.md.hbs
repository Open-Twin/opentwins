## SS 4. Comment Inline (Search/Feed)

LinkedIn inline comments use TipTap/ProseMirror editor (NOT Quill).

🚨 CRITICAL submit rules:
- ❌ NEVER use `textContent === 'Comment'` — it matches the toggle first!
- ✅ ALWAYS use `button[data-view-name="comment-post"]` to submit
- ✅ VERIFY by checking editor is EMPTY (`textContent.trim().length === 0`) — NOT `innerText.indexOf(snippet)` (always true while text in editor)

### Step 1: Like + open comment + type (ONE async evaluate)
```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    var TARGET_IDX = ${targetIdx};
    var items = document.querySelectorAll('div[role="listitem"]');
    var item = items[TARGET_IDX];
    if (!item) return { error: 'no-item at idx ' + TARGET_IDX };

    // Like (Type A)
    var likeBtn = item.querySelector('button[aria-label="Reaction button state: no reaction"]');
    var liked = false;
    if (likeBtn) { likeBtn.click(); liked = true; }

    // Open comment editor
    await new Promise(r => setTimeout(r, 1000));
    var commentBtn = item.querySelector('button[data-view-name="feed-comment-button"]');
    if (!commentBtn) return { liked: liked, error: 'no comment button' };
    commentBtn.click();

    // Wait for editor
    await new Promise(r => setTimeout(r, 2000));

    // Type
    var editor = item.querySelector('div.tiptap.ProseMirror[role="textbox"]');
    if (!editor) editor = item.querySelector('[contenteditable="true"][role="textbox"]');
    if (!editor) return { liked: liked, opened: true, error: 'no editor' };
    editor.focus();
    var text = "${commentText.replace(/"/g, '\\"').replace(/\n/g, '\\n')}";
    document.execCommand('insertText', false, text);

    await new Promise(r => setTimeout(r, 500));
    return {
      liked: liked,
      opened: true,
      typed: true,
      editorText: editor.textContent.slice(0, 80),
      submitExists: !!item.querySelector('button[data-view-name="comment-post"]')
    };
  }`,
  profile: "{{browser_profile}}"
})
```

### Step 2: Submit + verify (ONE async evaluate)
```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    var TARGET_IDX = ${targetIdx};
    var items = document.querySelectorAll('div[role="listitem"]');
    var item = items[TARGET_IDX];
    if (!item) return { error: 'no-item' };

    // Verify text in editor
    var editor = item.querySelector('div.tiptap.ProseMirror[role="textbox"]');
    if (!editor) editor = item.querySelector('[contenteditable="true"][role="textbox"]');
    if (!editor || !editor.textContent.trim()) return { error: 'editor empty or missing' };

    // Submit
    var submitBtn = item.querySelector('button[data-view-name="comment-post"]');
    if (!submitBtn) return { error: 'no submit button' };
    submitBtn.click();

    // Wait for submission
    await new Promise(r => setTimeout(r, 3000));

    // Verify: editor empty + snippet visible
    var editorAfter = item.querySelector('div.tiptap.ProseMirror[role="textbox"]');
    if (!editorAfter) editorAfter = item.querySelector('[contenteditable="true"][role="textbox"]');
    var editorEmpty = !editorAfter || editorAfter.textContent.trim().length === 0;
    var snippet = "${commentText.slice(0, 40).replace(/"/g, '\\"')}";
    var snippetInPage = item.innerText.indexOf(snippet) > -1;

    return { submitted: true, editorEmpty: editorEmpty, snippetVisible: snippetInPage, verified: editorEmpty && snippetInPage };
  }`,
  profile: "{{browser_profile}}"
})
```

If `verified: false`: retry ONCE. Still fails → do NOT log, retry with next post.

## SS 6. Like Posts (Batch) + Verify (ONE async evaluate)

```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    var maxLikes = ${maxLikes};
    var buttons = document.querySelectorAll('button');
    var unliked = [];
    for (var i = 0; i < buttons.length; i++) {
      var label = buttons[i].getAttribute('aria-label');
      if (label === 'Reaction button state: no reaction') unliked.push(buttons[i]);
    }
    var liked = 0;
    for (var i = 0; i < Math.min(maxLikes, unliked.length); i++) {
      unliked[i].click();
      liked++;
    }
    // Embedded verify wait
    await new Promise(r => setTimeout(r, 2000));
    var verifyBtns = document.querySelectorAll('button');
    var likedCount = 0;
    for (var j = 0; j < verifyBtns.length; j++) {
      if (verifyBtns[j].getAttribute('aria-label') === 'Reaction button state: Like') likedCount++;
    }
    return { totalUnliked: unliked.length, attempted: liked, totalLikedAfter: likedCount };
  }`,
  profile: "{{browser_profile}}"
})
```

## SS 7. Article Publishing

### Brand Links (use when article mentions the brand)
| Resource | URL |
|----------|-----|
| LinkedIn | linkedin.com/in/{{handle}} |
| GitHub tools | github.com/{{handle}} |
| BRAND.md | See identity config for full positioning |

### Step 1: Set title
```javascript
browser.act({
  kind: "evaluate",
  fn: `() => {
    var ta = document.querySelector('textarea.article-editor-headline__textarea');
    if (!ta) return { success: false, reason: 'no-title-textarea' };
    var nativeSetter = Object.getOwnPropertyDescriptor(window.HTMLTextAreaElement.prototype, 'value').set;
    nativeSetter.call(ta, "${articleTitle.replace(/"/g, '\\"')}");
    ta.dispatchEvent(new Event('input', { bubbles: true }));
    ta.dispatchEvent(new Event('change', { bubbles: true }));
    return { success: true, value: ta.value };
  }`,
  profile: "{{browser_profile}}"
})
```
Title textarea has maxLength=150. Do NOT use `type` or `fill` actions - they fail on this element.

### Step 2: Set body content (wait 1s after title)
```javascript
// articleHTML = '<p>First paragraph...</p><p><strong>Section heading</strong></p><p>Content...</p>'
browser.act({
  kind: "evaluate",
  fn: `() => {
    var editor = document.querySelector('[role="textbox"][aria-label="Article editor content"]');
    if (!editor) return { success: false, reason: 'no-editor' };
    editor.innerHTML = \`${articleHTML}\`;
    editor.dispatchEvent(new Event('input', { bubbles: true }));
    return { success: true, length: editor.innerText.length };
  }`,
  profile: "{{browser_profile}}"
})
```

**Article body rules:**
- Use `<p>` for paragraphs, `<strong>` for section headings
- Include brand link as `<a href="https://linkedin.com/in/{{handle}}">{{name}}</a>` or `<a href="https://github.com/{{handle}}">open-source tools in your field</a>` at least once in the article body
- Hashtags go in the share text (Step 4), NOT in article body
- Keep HTML under 8000 chars to avoid evaluate payload bloat

### Step 3: Click Next (wait 1s after body)
```javascript
browser.act({
  kind: "evaluate",
  fn: `() => {
    var buttons = document.querySelectorAll('button');
    for (var i = 0; i < buttons.length; i++) {
      if (buttons[i].innerText.trim() === 'Next') {
        buttons[i].click();
        return { clicked: true };
      }
    }
    return { clicked: false, reason: 'no-next-button' };
  }`,
  profile: "{{browser_profile}}"
})
```

### Step 4: Add share text with hashtags (wait 2s after Next for dialog)

The publish dialog has a Quill `.ql-editor` with placeholder "Tell your network what your article is about..."

```javascript
// shareText = "One-liner about article + 3-5 hashtags"
// Example: "47 meetings in one week taught me why meeting culture is broken - and what I built to fix it.\n\n#meetingculture #productivity #ai #buildinpublic #vibecoding"
browser.act({
  kind: "evaluate",
  fn: `() => {
    var editor = document.querySelector('.ql-editor[data-placeholder*="Tell your network"]');
    if (!editor) return { success: false, reason: 'no-share-editor' };
    editor.focus();
    var text = "${shareText.replace(/"/g, '\\"').replace(/\n/g, '\\n')}";
    editor.innerHTML = '<p>' + text.replace(/\\n/g, '</p><p>') + '</p>';
    editor.dispatchEvent(new Event('input', { bubbles: true }));
    editor.classList.remove('ql-blank');
    return { success: true, text: editor.innerText.slice(0, 100) };
  }`,
  profile: "{{browser_profile}}"
})
```

**Hashtag rules:** Pick 3-5 from queries.json `hashtags` array. Match article topic. Always include `#buildinpublic`.

### Step 5: Click Publish (wait 1s after share text)
```javascript
browser.act({
  kind: "evaluate",
  fn: `() => {
    var buttons = document.querySelectorAll('button');
    for (var i = 0; i < buttons.length; i++) {
      if (buttons[i].innerText.trim() === 'Publish' && !buttons[i].disabled) {
        buttons[i].click();
        return { clicked: true };
      }
    }
    return { clicked: false, reason: 'no-publish-button' };
  }`,
  profile: "{{browser_profile}}"
})
```

### Step 6: Verify (wait 5s after publish)
```javascript
browser.act({
  kind: "evaluate",
  fn: `() => {
    var url = window.location.href;
    return {
      published: url.indexOf('published=t') > -1 || url.indexOf('/pulse/') > -1,
      url: url,
      title: document.title
    };
  }`,
  profile: "{{browser_profile}}"
})
```

If NOT published (still on edit page): wait 3s, check URL again. If still not published after 2 attempts: log error, do NOT mark task done.
