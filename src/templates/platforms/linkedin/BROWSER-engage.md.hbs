## SS 4. Comment Inline (Search/Feed)

LinkedIn inline comments use TipTap/ProseMirror editor (NOT Quill).

🚨 CRITICAL submit rules:
- ❌ NEVER use `textContent === 'Comment'` — it matches the toggle first!
- ✅ ALWAYS use `button[data-view-name="comment-post"]` to submit
- ✅ VERIFY by checking editor is EMPTY (`textContent.trim().length === 0`) — NOT `innerText.indexOf(snippet)` (always true while text in editor)

### Step 1: Like + open comment + type (ONE async evaluate)
```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    var TARGET_IDX = ${targetIdx};
    var items = document.querySelectorAll('div[role="listitem"]');
    var item = items[TARGET_IDX];
    if (!item) return { error: 'no-item at idx ' + TARGET_IDX };

    // Like (Type A)
    var likeBtn = item.querySelector('button[aria-label="Reaction button state: no reaction"]');
    var liked = false;
    if (likeBtn) { likeBtn.click(); liked = true; }

    // Open comment editor
    await new Promise(r => setTimeout(r, 1000));
    var commentBtn = item.querySelector('button[data-view-name="feed-comment-button"]');
    if (!commentBtn) return { liked: liked, error: 'no comment button' };
    commentBtn.click();

    // Wait for editor
    await new Promise(r => setTimeout(r, 2000));

    // Type
    var editor = item.querySelector('div.tiptap.ProseMirror[role="textbox"]');
    if (!editor) editor = item.querySelector('[contenteditable="true"][role="textbox"]');
    if (!editor) return { liked: liked, opened: true, error: 'no editor' };
    editor.focus();
    var text = "${commentText.replace(/"/g, '\\"').replace(/\n/g, '\\n')}";
    document.execCommand('insertText', false, text);

    await new Promise(r => setTimeout(r, 500));
    return {
      liked: liked,
      opened: true,
      typed: true,
      editorText: editor.textContent.slice(0, 80),
      submitExists: !!item.querySelector('button[data-view-name="comment-post"]')
    };
  }`,
  profile: "{{browser_profile}}"
})
```

### Step 2: Submit + verify (ONE async evaluate)
🚨 **Verification MUST check the comment list, not the editor.** The editor can be empty AND the comment can still have failed (LinkedIn silently rejects empty content). We need to find our comment URN in the rendered comment list.

```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    var TARGET_IDX = ${targetIdx};
    var items = document.querySelectorAll('div[role="listitem"]');
    var item = items[TARGET_IDX];
    if (!item) return { error: 'no-item' };

    // Verify text in editor before submitting
    var editor = item.querySelector('div.tiptap.ProseMirror[role="textbox"]');
    if (!editor) editor = item.querySelector('[contenteditable="true"][role="textbox"]');
    if (!editor || !editor.textContent.trim()) return { error: 'editor empty or missing' };

    // Submit
    var submitBtn = item.querySelector('button[data-view-name="comment-post"]');
    if (!submitBtn) return { error: 'no submit button' };
    submitBtn.click();

    // Wait for submission + render
    await new Promise(r => setTimeout(r, 4000));

    // 🚨 AUTHORITATIVE VERIFY: find our comment in the comment list
    // Look for articles/divs with our author link as child, containing our snippet
    var snippet = "${commentText.slice(0, 35).replace(/"/g, '\\"')}";
    var allAuthorLinks = item.querySelectorAll('a[href*="/in/{{handle_slug}}"]');
    var ourCommentFound = false;
    for (var i = 0; i < allAuthorLinks.length; i++) {
      // Walk up to find the comment container, then search its text for our snippet
      var parent = allAuthorLinks[i].closest('article') || allAuthorLinks[i].closest('[class*="comment-entity"]') || allAuthorLinks[i].closest('[data-urn*="comment"]');
      if (!parent) parent = allAuthorLinks[i].parentElement;
      for (var hops = 0; hops < 6 && parent; hops++) {
        if (parent.innerText && parent.innerText.indexOf(snippet) > -1 && !parent.querySelector('[role="textbox"]')) {
          ourCommentFound = true;
          break;
        }
        parent = parent.parentElement;
      }
      if (ourCommentFound) break;
    }

    // Also verify editor is empty as secondary signal
    var editorAfter = item.querySelector('div.tiptap.ProseMirror[role="textbox"]');
    if (!editorAfter) editorAfter = item.querySelector('[contenteditable="true"][role="textbox"]');
    var editorEmpty = !editorAfter || editorAfter.textContent.trim().length === 0;

    return {
      submitted: true,
      editorEmpty: editorEmpty,
      ourCommentFound: ourCommentFound,
      verified: ourCommentFound  // authoritative: must find our comment in the DOM
    };
  }`,
  profile: "{{browser_profile}}"
})
```

If `verified: false`: retry ONCE. Still fails → do NOT log, do NOT increment counters, skip to next post.

