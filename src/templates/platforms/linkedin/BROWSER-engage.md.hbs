## SS 4. Comment Inline (Search/Feed — TipTap editor)

### Step 1: Like + open comment + type (ONE evaluate)

Replace `${targetIdx}` with the post index from extraction, `${commentText}` with your comment.

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { var TARGET_IDX = ${targetIdx}; var items = document.querySelectorAll('div[role=\"listitem\"]'); var item = items[TARGET_IDX]; if (!item) return { error: 'no-item at idx ' + TARGET_IDX }; var likeBtn = item.querySelector('button[aria-label=\"Reaction button state: no reaction\"]'); var liked = false; if (likeBtn) { likeBtn.click(); liked = true; } await new Promise(r => setTimeout(r, 1000)); var allBtns = Array.from(item.querySelectorAll('button')); var commentBtn = allBtns.find(function(b) { return b.innerText.trim() === 'Comment' && b.offsetParent !== null; }); if (!commentBtn) return { liked: liked, error: 'no comment button' }; commentBtn.click(); await new Promise(r => setTimeout(r, 2000)); var editor = item.querySelector('div.tiptap.ProseMirror[role=\"textbox\"]'); if (!editor) editor = item.querySelector('[contenteditable=\"true\"][role=\"textbox\"]'); if (!editor) return { liked: liked, opened: true, error: 'no editor' }; editor.focus(); document.execCommand('insertText', false, '${commentText}'); await new Promise(r => setTimeout(r, 500)); var commentBtns = Array.from(item.querySelectorAll('button')).filter(function(b) { return b.innerText.trim() === 'Comment' && b.offsetParent !== null; }); return { liked: liked, opened: true, typed: true, editorText: editor.textContent.slice(0, 80), submitExists: commentBtns.length > 1 }; }"}
ENDJSON
```

### Step 2: Submit + verify (ONE evaluate)

Replace `${targetIdx}` and `${commentSnippet}` (first 35 chars of your comment).

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { var TARGET_IDX = ${targetIdx}; var items = document.querySelectorAll('div[role=\"listitem\"]'); var item = items[TARGET_IDX]; if (!item) return { error: 'no-item' }; var editor = item.querySelector('div.tiptap.ProseMirror[role=\"textbox\"]'); if (!editor) editor = item.querySelector('[contenteditable=\"true\"][role=\"textbox\"]'); if (!editor || !editor.textContent.trim()) return { error: 'editor empty or missing' }; var commentBtns = Array.from(item.querySelectorAll('button')).filter(function(b) { return b.innerText.trim() === 'Comment' && b.offsetParent !== null; }); var submitBtn = commentBtns.length > 1 ? commentBtns[commentBtns.length - 1] : null; if (!submitBtn) return { error: 'no submit button' }; submitBtn.click(); await new Promise(r => setTimeout(r, 4000)); var snippet = '${commentSnippet}'; var allAuthorLinks = item.querySelectorAll('a[href*=\"/in/{{handle_slug}}\"]'); var ourCommentFound = false; for (var i = 0; i < allAuthorLinks.length; i++) { var parent = allAuthorLinks[i].closest('article') || allAuthorLinks[i].closest('[class*=\"comment-entity\"]') || allAuthorLinks[i].closest('[data-urn*=\"comment\"]'); if (!parent) parent = allAuthorLinks[i].parentElement; for (var hops = 0; hops < 6 && parent; hops++) { if (parent.innerText && parent.innerText.indexOf(snippet) > -1 && !parent.querySelector('[role=\"textbox\"]')) { ourCommentFound = true; break; } parent = parent.parentElement; } if (ourCommentFound) break; } var editorAfter = item.querySelector('div.tiptap.ProseMirror[role=\"textbox\"]'); if (!editorAfter) editorAfter = item.querySelector('[contenteditable=\"true\"][role=\"textbox\"]'); var editorEmpty = !editorAfter || editorAfter.textContent.trim().length === 0; return { submitted: true, editorEmpty: editorEmpty, ourCommentFound: ourCommentFound, verified: ourCommentFound }; }"}
ENDJSON
```

If `verified: false`: retry ONCE. Still fails → skip to next post.

