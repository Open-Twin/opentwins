## SS 4b. Comment on Pulse Article (Quill Editor)

🚨 **Pulse articles use QUILL editor, NOT TipTap.** `execCommand('insertText')` leaves Quill's Delta state empty → submit silently rejected. Must use Quill API.

### Step 1: Scroll to comments + insert via Quill API

Replace `${commentText}` with your comment.

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { window.scrollTo(0, document.body.scrollHeight); await new Promise(r => setTimeout(r, 2500)); var composer = document.querySelector('.ql-editor[contenteditable=\"true\"]') || document.querySelector('[class*=\"comments-comment-box\"] [contenteditable=\"true\"]'); if (!composer) { var placeholder = document.querySelector('[class*=\"comments-comment-box__comment-input\"]') || document.querySelector('button[aria-label*=\"Comment\"]'); if (placeholder) { placeholder.click(); await new Promise(r => setTimeout(r, 1500)); } composer = document.querySelector('.ql-editor[contenteditable=\"true\"]') || document.querySelector('[class*=\"comments-comment-box\"] [contenteditable=\"true\"]'); } if (!composer) return { error: 'no_quill_editor_found' }; var qlContainer = composer.closest('.ql-container') || composer.parentElement; var quillInstance = null; if (typeof window.Quill !== 'undefined' && window.Quill.find) { quillInstance = window.Quill.find(qlContainer); } if (!quillInstance) { var probe = composer; while (probe && !quillInstance) { if (probe.__quill) quillInstance = probe.__quill; probe = probe.parentElement; } } var text = '${commentText}'; if (quillInstance) { quillInstance.setText(text); quillInstance.setSelection(text.length, 0, 'user'); } else { composer.focus(); composer.innerHTML = ''; document.execCommand('insertText', false, text); composer.dispatchEvent(new Event('input', { bubbles: true })); } await new Promise(r => setTimeout(r, 800)); return { editorFound: true, quillInstanceUsed: !!quillInstance, textInserted: (composer.innerText || '').trim().length > 0, preview: (composer.innerText || '').slice(0, 80) }; }"}
ENDJSON
```

If `textInserted: false` → skip this target.

### Step 2: Submit + verify

Replace `${commentSnippet}` with first 35 chars of your comment.

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { var composer = document.querySelector('.ql-editor[contenteditable=\"true\"]'); var form = composer ? composer.closest('form') : null; if (!form) return { error: 'no_form' }; var btns = Array.from(form.querySelectorAll('button')); var submitBtn = btns.find(function(b) { var label = (b.getAttribute('aria-label') || '').toLowerCase(); return label.indexOf('post comment on') === 0; }); if (!submitBtn) submitBtn = form.querySelector('button[data-view-name=\"comment-post\"]'); if (!submitBtn) return { error: 'no_submit_button' }; if (submitBtn.disabled || submitBtn.getAttribute('aria-disabled') === 'true') return { error: 'submit_disabled' }; submitBtn.click(); await new Promise(r => setTimeout(r, 5000)); var snippet = '${commentSnippet}'; var ourLinks = Array.from(document.querySelectorAll('a[href*=\"/in/{{handle_slug}}\"]')); var ourCommentFound = false; for (var i = 0; i < ourLinks.length; i++) { if (ourLinks[i].href.includes('sidebar_menu') || ourLinks[i].href.includes('author')) continue; var parent = ourLinks[i].closest('article') || ourLinks[i].closest('[class*=\"comment-entity\"]') || ourLinks[i].closest('[data-urn*=\"comment\"]'); if (!parent) parent = ourLinks[i].parentElement; for (var hops = 0; hops < 8 && parent; hops++) { if (parent.innerText && parent.innerText.indexOf(snippet) > -1 && !parent.querySelector('[role=\"textbox\"]') && !parent.querySelector('.ql-editor')) { ourCommentFound = true; break; } parent = parent.parentElement; } if (ourCommentFound) break; } var editorAfter = document.querySelector('.ql-editor[contenteditable=\"true\"]'); var editorEmpty = !editorAfter || (editorAfter.innerText || '').trim().length === 0; return { submitted: true, editorEmpty: editorEmpty, ourCommentFound: ourCommentFound, verified: ourCommentFound }; }"}
ENDJSON
```

If `verified: false`: retry Step 1 + Step 2 ONCE. Still fails → skip.

## SS 6. Like Posts (Batch)

Replace `${maxLikes}` with the number of likes to do.

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { var maxLikes = ${maxLikes}; var buttons = document.querySelectorAll('button'); var unliked = []; for (var i = 0; i < buttons.length; i++) { var label = buttons[i].getAttribute('aria-label'); if (label === 'Reaction button state: no reaction') unliked.push(buttons[i]); } var liked = 0; for (var i = 0; i < Math.min(maxLikes, unliked.length); i++) { unliked[i].click(); liked++; } await new Promise(r => setTimeout(r, 2000)); var verifyBtns = document.querySelectorAll('button'); var likedCount = 0; for (var j = 0; j < verifyBtns.length; j++) { if (verifyBtns[j].getAttribute('aria-label') === 'Reaction button state: Like') likedCount++; } return { totalUnliked: unliked.length, attempted: liked, totalLikedAfter: likedCount }; }"}
ENDJSON
```

## SS 7. Article Publishing

### Brand Links
| Resource | URL |
|----------|-----|
| LinkedIn | linkedin.com/in/{{handle_slug}} |
| GitHub | github.com/{{handle_slug}} |

### Step 1: Set title

Replace `${articleTitle}`.

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { var ta = document.querySelector('textarea.article-editor-headline__textarea'); if (!ta) return { success: false, reason: 'no-title-textarea' }; var nativeSetter = Object.getOwnPropertyDescriptor(window.HTMLTextAreaElement.prototype, 'value').set; nativeSetter.call(ta, '${articleTitle}'); ta.dispatchEvent(new Event('input', { bubbles: true })); ta.dispatchEvent(new Event('change', { bubbles: true })); return { success: true, value: ta.value }; }"}
ENDJSON
```

### Step 2: Set body content

Replace `${articleHTML}` with HTML string using `<p>`, `<strong>`, `<a>`.

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { await new Promise(r => setTimeout(r, 1000)); var editor = document.querySelector('[role=\"textbox\"][aria-label=\"Article editor content\"]'); if (!editor) return { success: false, reason: 'no-editor' }; editor.innerHTML = '${articleHTML}'; editor.dispatchEvent(new Event('input', { bubbles: true })); return { success: true, length: editor.innerText.length }; }"}
ENDJSON
```

### Step 3: Click Next

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { await new Promise(r => setTimeout(r, 1000)); var buttons = document.querySelectorAll('button'); for (var i = 0; i < buttons.length; i++) { if (buttons[i].innerText.trim() === 'Next') { buttons[i].click(); return { clicked: true }; } } return { clicked: false, reason: 'no-next-button' }; }"}
ENDJSON
```

### Step 4: Add share text with hashtags

Replace `${shareText}` with one-liner + hashtags.

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { await new Promise(r => setTimeout(r, 2000)); var editor = document.querySelector('.ql-editor[data-placeholder*=\"Tell your network\"]'); if (!editor) return { success: false, reason: 'no-share-editor' }; editor.focus(); editor.innerHTML = '<p>${shareText}</p>'; editor.dispatchEvent(new Event('input', { bubbles: true })); editor.classList.remove('ql-blank'); return { success: true, text: editor.innerText.slice(0, 100) }; }"}
ENDJSON
```

### Step 5: Click Publish

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { await new Promise(r => setTimeout(r, 1000)); var buttons = document.querySelectorAll('button'); for (var i = 0; i < buttons.length; i++) { if (buttons[i].innerText.trim() === 'Publish' && !buttons[i].disabled) { buttons[i].click(); return { clicked: true }; } } return { clicked: false, reason: 'no-publish-button' }; }"}
ENDJSON
```

### Step 6: Verify

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { await new Promise(r => setTimeout(r, 5000)); var url = window.location.href; return { published: url.indexOf('published=t') > -1 || url.indexOf('/pulse/') > -1, url: url, title: document.title }; }"}
ENDJSON
```

If NOT published after 2 attempts: log error, do NOT mark task done.
