## SS 2. Extract Search Results

```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    await new Promise(r => setTimeout(r, 3000));
    var items = document.querySelectorAll('div[role="listitem"]');
    var posts = [];
    for (var i = 0; i < Math.min(items.length, 10); i++) {
      var item = items[i];
      var text = item.innerText;
      if (text.length < 100) continue;
      var lines = text.split('\\n').filter(function(l) { return l.trim().length > 0; });
      var promoted = text.indexOf('Promoted') > -1;
      if (promoted) continue;
      var rm = text.match(/(\\d+)\\s+reaction/);
      var cm = text.match(/(\\d+)\\s+comment/);
      var likeBtn = item.querySelector('button[aria-label="Reaction button state: no reaction"]');
      var isLiked = item.querySelector('button[aria-label="Reaction button state: Like"]');
      // Extract post URL — priority: /feed/update/ first (has activity ID), then /pulse/, skip /company/posts/
      var allLinks = item.querySelectorAll('a');
      var feedUrl = null;
      var pulseUrl = null;
      var profileUrl = null;
      for (var k = 0; k < allLinks.length; k++) {
        var href = allLinks[k].href;
        if (!feedUrl && href.indexOf('/feed/update/') > -1) feedUrl = href;
        if (!pulseUrl && href.indexOf('/pulse/') > -1) pulseUrl = href;
        if (!profileUrl && href.indexOf('/in/') > -1 && allLinks[k].innerText.trim().length > 0) profileUrl = href;
      }
      var postUrl = feedUrl || pulseUrl || null;
      var username = profileUrl ? (profileUrl.match(/\/in\/([^/?]+)/) || [])[1] : '';
      var isPulse = !!pulseUrl && !feedUrl;
      // Extract trackable ID: numeric ID from feed URLs, slug from Pulse
      var trackId = '';
      if (feedUrl) { var m = feedUrl.match(/(\d{16,20})/); trackId = m ? m[1] : ''; }
      else if (pulseUrl) { var s = pulseUrl.match(/\/pulse\/([^/?]+)/); trackId = s ? s[1] : ''; }
      // Age: extract from "4d • " or "1w • " pattern in text lines
      var ageLine = lines.find(function(l) { return /^\\d+[dhwm]\\s/.test(l.trim()); });
      var age = ageLine ? ageLine.trim().split(' ')[0] : '';
      var tooOld = /\\d+(w|mo|yr)/.test(age) && !(age === '1w');
      posts.push({
        idx: i,
        author: lines.length > 1 ? lines[1].slice(0, 60) : '',
        username: username,
        headline: lines.length > 3 ? lines[3].slice(0, 100) : '',
        postUrl: postUrl,
        trackId: trackId,
        isPulse: isPulse,
        age: age,
        tooOld: tooOld,
        content: text.slice(0, 400),
        reactions: rm ? parseInt(rm[1]) : 0,
        comments: cm ? parseInt(cm[1]) : 0,
        notLiked: !!likeBtn,
        alreadyLiked: !!isLiked
      });
    }
    return posts;
  }`,
  profile: "{{browser_profile}}"
})
```

