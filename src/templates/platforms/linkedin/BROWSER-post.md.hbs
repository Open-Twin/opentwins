### Step 3: Fill question
```javascript
// pollQuestion = "How much do you trust AI-generated code in production?"
browser.act({
  kind: "evaluate",
  fn: `() => {
    var host = document.querySelector('#interop-outlet');
    var shadow = host.shadowRoot;
    var ta = shadow.querySelector('textarea[placeholder*="How do you commute"]') ||
             Array.from(shadow.querySelectorAll('textarea')).find(t => t.className.includes('polls-detour'));
    if (!ta) return { success: false, reason: 'no-question-textarea' };
    var nativeSetter = Object.getOwnPropertyDescriptor(window.HTMLTextAreaElement.prototype, 'value').set;
    nativeSetter.call(ta, "${pollQuestion}");
    ta.dispatchEvent(new Event('input', { bubbles: true }));
    ta.dispatchEvent(new Event('change', { bubbles: true }));
    return { success: true, value: ta.value };
  }`,
  profile: "{{browser_profile}}"
})
```

### Step 4: Fill options 1 and 2

🚨 **Always `.slice(0, 30)` — options over 30 chars disable the Done button silently.**

```javascript
// option1 = "Full trust - ship it", option2 = "Trust but verify manually"
browser.act({
  kind: "evaluate",
  fn: `() => {
    var host = document.querySelector('#interop-outlet');
    var shadow = host.shadowRoot;
    var opt1 = shadow.querySelector('#poll-option-1');
    var opt2 = shadow.querySelector('#poll-option-2');
    if (!opt1 || !opt2) return { success: false, reason: 'no-option-inputs' };
    var setter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value').set;
    setter.call(opt1, "${option1}".slice(0, 30));
    opt1.dispatchEvent(new Event('input', { bubbles: true }));
    opt1.dispatchEvent(new Event('change', { bubbles: true }));
    setter.call(opt2, "${option2}".slice(0, 30));
    opt2.dispatchEvent(new Event('input', { bubbles: true }));
    opt2.dispatchEvent(new Event('change', { bubbles: true }));
    return { success: true, opt1: opt1.value, opt1Len: opt1.value.length, opt2: opt2.value, opt2Len: opt2.value.length };
  }`,
  profile: "{{browser_profile}}"
})
```

