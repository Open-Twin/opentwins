## SS 10. Create Regular Post (Text Only)

### Step 1: Open modal (SS 8), wait 2s

### Step 2: Type post text
```javascript
// postContent = "Your post text here"
browser.act({
  kind: "evaluate",
  fn: `() => {
    var host = document.querySelector('#interop-outlet');
    var shadow = host.shadowRoot;
    var editor = shadow.querySelector('.ql-editor[role="textbox"]') ||
                 shadow.querySelector('[contenteditable="true"][role="textbox"]');
    if (!editor) return { success: false, reason: 'no-editor' };
    editor.focus();
    var lines = "${postContent}".split('\\n');
    editor.innerHTML = lines.map(function(line) { return '<p>' + (line.trim() === '' ? '<br>' : line) + '</p>'; }).join('');
    editor.dispatchEvent(new Event('input', { bubbles: true }));
    return { success: true, length: editor.innerText.length };
  }`,
  profile: "{{browser_profile}}"
})
```

