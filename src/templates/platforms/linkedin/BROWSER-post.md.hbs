# BROWSER-post.md - LinkedIn Post Creation, Poll & Repost Patterns

## Shadow DOM

LinkedIn's post/poll/repost creation modal lives inside shadow DOM. All modal UI elements are inside `#interop-outlet` shadowRoot:
```javascript
const host = document.querySelector('#interop-outlet');
const shadow = host.shadowRoot;
shadow.querySelector('button');  // finds modal buttons
```

---

## SS 8. Open Post Creation Modal

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { var host = document.querySelector('#interop-outlet'); if (host && host.shadowRoot) { var editor = host.shadowRoot.querySelector('[contenteditable=\"true\"][role=\"textbox\"]'); if (editor) return { alreadyOpen: true }; } var startBtn = Array.from(document.querySelectorAll('p, div, button')).find(function(el) { return el.textContent && el.textContent.trim() === 'Start a post' && el.offsetParent !== null && el.children.length === 0; }); if (!startBtn) return { success: false, reason: 'no-start-post-button' }; startBtn.click(); return { success: true }; }"}
ENDJSON
```

Wait 2s. Verify modal opened:

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { await new Promise(r => setTimeout(r, 2000)); var host = document.querySelector('#interop-outlet'); if (!host || !host.shadowRoot) return { open: false, reason: 'no-shadow-root' }; var shadow = host.shadowRoot; var btns = Array.from(shadow.querySelectorAll('button')); return { open: btns.length > 3, buttons: btns.map(b => ({ text: (b.innerText || '').trim().slice(0, 30), label: b.getAttribute('aria-label') || '' })) }; }"}
ENDJSON
```

## SS 9. Create Poll

### Poll option limit: 30 characters max. Always `.slice(0, 30)` option text.

### Step 2: Click "More" then "Create a poll"

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { var host = document.querySelector('#interop-outlet'); var shadow = host.shadowRoot; var moreBtn = Array.from(shadow.querySelectorAll('button')).find(b => b.getAttribute('aria-label') === 'More'); if (!moreBtn) return { success: false, reason: 'no-more-button' }; moreBtn.click(); await new Promise(r => setTimeout(r, 1000)); var pollBtn = Array.from(shadow.querySelectorAll('button')).find(b => b.getAttribute('aria-label') === 'Create a poll'); if (!pollBtn) return { success: false, reason: 'no-poll-button' }; pollBtn.click(); return { success: true }; }"}
ENDJSON
```

Wait 2s for poll form.

### Step 3: Fill question

Replace `${pollQuestion}`.

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { await new Promise(r => setTimeout(r, 1000)); var host = document.querySelector('#interop-outlet'); var shadow = host.shadowRoot; var ta = shadow.querySelector('textarea[placeholder*=\"How do you commute\"]') || Array.from(shadow.querySelectorAll('textarea')).find(t => t.className.includes('polls-detour')); if (!ta) return { success: false, reason: 'no-question-textarea' }; var nativeSetter = Object.getOwnPropertyDescriptor(window.HTMLTextAreaElement.prototype, 'value').set; nativeSetter.call(ta, '${pollQuestion}'); ta.dispatchEvent(new Event('input', { bubbles: true })); ta.dispatchEvent(new Event('change', { bubbles: true })); return { success: true, value: ta.value }; }"}
ENDJSON
```

### Step 4: Fill options 1 and 2

Replace `${option1}` and `${option2}`.

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { var host = document.querySelector('#interop-outlet'); var shadow = host.shadowRoot; var opt1 = shadow.querySelector('#poll-option-1'); var opt2 = shadow.querySelector('#poll-option-2'); if (!opt1 || !opt2) return { success: false, reason: 'no-option-inputs' }; var setter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value').set; setter.call(opt1, '${option1}'.slice(0, 30)); opt1.dispatchEvent(new Event('input', { bubbles: true })); opt1.dispatchEvent(new Event('change', { bubbles: true })); setter.call(opt2, '${option2}'.slice(0, 30)); opt2.dispatchEvent(new Event('input', { bubbles: true })); opt2.dispatchEvent(new Event('change', { bubbles: true })); return { success: true, opt1: opt1.value, opt2: opt2.value }; }"}
ENDJSON
```

### Step 5: Add option 3 (click "Add option", wait 1s, fill)

Replace `${option3}`.

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { var host = document.querySelector('#interop-outlet'); var shadow = host.shadowRoot; var addBtn = Array.from(shadow.querySelectorAll('button')).find(b => (b.innerText || '').includes('Add option')); if (!addBtn) return { success: false, reason: 'no-add-option-button' }; addBtn.click(); await new Promise(r => setTimeout(r, 1000)); var opt3 = shadow.querySelector('#poll-option-3'); if (!opt3) return { success: false, reason: 'no-option-3' }; var setter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value').set; setter.call(opt3, '${option3}'.slice(0, 30)); opt3.dispatchEvent(new Event('input', { bubbles: true })); opt3.dispatchEvent(new Event('change', { bubbles: true })); return { success: true, value: opt3.value }; }"}
ENDJSON
```

### Step 6: Add option 4 (same pattern)

Replace `${option4}`.

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { var host = document.querySelector('#interop-outlet'); var shadow = host.shadowRoot; var addBtn = Array.from(shadow.querySelectorAll('button')).find(b => (b.innerText || '').includes('Add option')); if (addBtn) addBtn.click(); await new Promise(r => setTimeout(r, 1000)); var opt4 = shadow.querySelector('#poll-option-4'); if (!opt4) return { success: false, reason: 'no-option-4' }; var setter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value').set; setter.call(opt4, '${option4}'.slice(0, 30)); opt4.dispatchEvent(new Event('input', { bubbles: true })); opt4.dispatchEvent(new Event('change', { bubbles: true })); return { success: true, value: opt4.value }; }"}
ENDJSON
```

### Step 7: Click "Done"

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { var host = document.querySelector('#interop-outlet'); var shadow = host.shadowRoot; var doneBtn = Array.from(shadow.querySelectorAll('button')).find(b => (b.innerText || '').trim() === 'Done'); if (!doneBtn) return { success: false, reason: 'no-done-button' }; doneBtn.click(); return { success: true }; }"}
ENDJSON
```

Wait 2s for poll preview.

### Step 8: Add post text (optional intro above poll)

Replace `${postText}`.

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { await new Promise(r => setTimeout(r, 1000)); var host = document.querySelector('#interop-outlet'); var shadow = host.shadowRoot; var editor = shadow.querySelector('.ql-editor[role=\"textbox\"]') || shadow.querySelector('[contenteditable=\"true\"][role=\"textbox\"]'); if (!editor) return { success: false, reason: 'no-editor' }; editor.focus(); editor.innerHTML = '<p>${postText}</p>'; editor.dispatchEvent(new Event('input', { bubbles: true })); return { success: true, length: editor.innerText.length }; }"}
ENDJSON
```

### Step 9: Click "Post"

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { await new Promise(r => setTimeout(r, 1000)); var host = document.querySelector('#interop-outlet'); var shadow = host.shadowRoot; var postBtn = Array.from(shadow.querySelectorAll('button')).find(b => (b.innerText || '').trim() === 'Post' && !b.disabled); if (!postBtn) return { success: false, reason: 'post-button-not-ready' }; postBtn.click(); return { success: true }; }"}
ENDJSON
```

Wait 4s.

### Step 10: Dismiss verification prompt + get post URL

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { await new Promise(r => setTimeout(r, 2000)); var host = document.querySelector('#interop-outlet'); var shadow = host ? host.shadowRoot : null; if (shadow) { var notNow = Array.from(shadow.querySelectorAll('button')).find(b => (b.innerText || '').includes('Not now')); if (notNow) notNow.click(); } await new Promise(r => setTimeout(r, 1000)); var links = Array.from(document.querySelectorAll('a')); var postLink = links.find(a => a.href && a.href.includes('/feed/update/urn:li:ugcPost:')); return { dismissed: true, url: postLink ? postLink.href : null }; }"}
ENDJSON
```

