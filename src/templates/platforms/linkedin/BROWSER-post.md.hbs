## SS 11. Repost with Commentary

### Step 1: Click Repost → "Repost with your thoughts"

Replace `${targetMinY}` and `${targetMaxY}` with the Y-coordinate range of the target post's Repost button.

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { await new Promise(r => setTimeout(r, 1000)); var allBtns = Array.from(document.querySelectorAll('button')); var repostBtns = allBtns.filter(function(b) { return b.innerText.trim() === 'Repost' && b.offsetParent !== null; }); var targetBtn = repostBtns.find(function(b) { var top = b.getBoundingClientRect().top; return top > ${targetMinY} && top < ${targetMaxY}; }); if (!targetBtn) return { error: 'no Repost button in range', count: repostBtns.length }; targetBtn.click(); await new Promise(r => setTimeout(r, 1500)); var allDivs = Array.from(document.querySelectorAll('div')); var thoughtsDiv = allDivs.find(function(d) { var t = (d.textContent || '').trim(); return d.offsetParent !== null && t.startsWith('Repost with your thoughts') && t.length < 100; }); if (!thoughtsDiv) return { repostClicked: true, error: 'no thoughts option' }; thoughtsDiv.click(); await new Promise(r => setTimeout(r, 3000)); var host = document.querySelector('#interop-outlet'); if (!host || !host.shadowRoot) return { repostClicked: true, thoughtsClicked: true, error: 'no shadow root' }; var editor = host.shadowRoot.querySelector('.ql-editor'); return { repostClicked: true, thoughtsClicked: true, editorReady: !!editor }; }"}
ENDJSON
```

### Step 2: Type commentary + click Post

Replace `${commentaryText}`.

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { var host = document.querySelector('#interop-outlet'); if (!host || !host.shadowRoot) return { error: 'no shadow root' }; var editor = host.shadowRoot.querySelector('.ql-editor'); if (!editor) return { error: 'no editor' }; editor.focus(); editor.innerHTML = '<p>${commentaryText}</p>'; editor.dispatchEvent(new Event('input', { bubbles: true })); await new Promise(r => setTimeout(r, 1000)); var postBtn = Array.from(host.shadowRoot.querySelectorAll('button')).find(function(b) { return b.innerText.trim() === 'Post' && !b.disabled; }); if (!postBtn) return { typed: true, error: 'no Post button' }; postBtn.click(); await new Promise(r => setTimeout(r, 3000)); var editorGone = !host.shadowRoot.querySelector('.ql-editor'); return { posted: true, editorGone: editorGone }; }"}
ENDJSON
```

Verify: editor should be gone after post. Log as Type=Repost.
