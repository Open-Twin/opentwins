### Step 10: Dismiss verification prompt + verify
```javascript
browser.act({
  kind: "evaluate",
  fn: `() => {
    var host = document.querySelector('#interop-outlet');
    var shadow = host ? host.shadowRoot : null;
    if (shadow) {
      var notNow = Array.from(shadow.querySelectorAll('button')).find(
        b => (b.innerText || '').includes('Not now')
      );
      if (notNow) notNow.click();
    }
    return { dismissed: true, url: window.location.href };
  }`,
  profile: "{{browser_profile}}"
})
```

