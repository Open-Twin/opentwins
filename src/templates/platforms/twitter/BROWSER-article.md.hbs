## Step 1 — Navigate to Articles and create new draft

```javascript
browser.navigate("https://x.com/compose/articles", { profile: "{{browser_profile}}" })
// Wait 3s, then click Write/create button
browser.act({
  kind: "evaluate",
  fn: `() => {
    return new Promise(resolve => setTimeout(() => {
      const createBtn = document.querySelector('button[aria-label="create"]');
      if (createBtn) { createBtn.click(); return resolve({ clicked: 'create' }); }
      const writeBtn = document.querySelector('[data-testid="empty_state_button_text"]')
                    || Array.from(document.querySelectorAll('a, button')).find(b => b.innerText.trim() === 'Write');
      if (writeBtn) { writeBtn.click(); return resolve({ clicked: 'write' }); }
      resolve({ error: 'no Write/create button' });
    }, 3000));
  }`,
  profile: "{{browser_profile}}"
})
// Wait 3s for editor to load — URL changes to /compose/articles/edit/{id}
```

---

## Step 2 — Type title (CDP type via snapshot)

```
snapshot('textarea[name="Article Title"]') → textbox [ref=eN]
browser.type(eN, "Article Title Here")
```

🚨 Title MUST be typed before body paste — this initializes the Draft.js editor for multi-block paste.

---

## Step 3 — Paste body with rich HTML

Build HTML string with formatting, mentions, hashtags. Then paste:

```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    var editor = document.querySelector('[data-testid="composer"]');
    if (!editor) return { error: 'no editor' };
    editor.focus();
    editor.click();
    await new Promise(function(r) { setTimeout(r, 500); });

    var html = ${JSON.stringify(articleHtml)};
    var plain = ${JSON.stringify(articlePlainText)};

    var dt = new DataTransfer();
    dt.setData('text/plain', plain);
    dt.setData('text/html', html);
    var pasteEvent = new ClipboardEvent('paste', { clipboardData: dt, bubbles: true, cancelable: true });
    editor.dispatchEvent(pasteEvent);

    await new Promise(function(r) { setTimeout(r, 3000); });
    var result = editor.innerText;
    var blockCount = editor.querySelectorAll('[data-block]').length;
    return { pasted: true, wordCount: result.split(/\\s+/).length, blocks: blockCount };
  }`,
  profile: "{{browser_profile}}"
})
```

Wait 5s after paste for auto-save before publishing.

---

## Step 4 — Publish (two-click flow)

**Click 1 — Open publish dialog:**
```javascript
browser.act({
  kind: "evaluate",
  fn: `() => {
    var btns = Array.from(document.querySelectorAll('button'));
    var publishBtn = btns.find(function(b) { return b.innerText.trim() === 'Publish'; });
    if (!publishBtn) return { error: 'no publish button' };
    publishBtn.click();
    return { clicked: true };
  }`,
  profile: "{{browser_profile}}"
})
```

Wait 2s. Dialog shows: audience (default "Everyone"), reply settings, timeline preview.

**Click 2 — Confirm publish:**
```javascript
browser.act({
  kind: "evaluate",
  fn: `async () => {
    await new Promise(function(r) { setTimeout(r, 2000); });
    var btns = Array.from(document.querySelectorAll('button'));
    var publishBtn = btns.find(function(b) { return b.innerText.trim() === 'Publish' && b.getAttribute('aria-label') === 'Publish'; });
    if (!publishBtn) return { error: 'no dialog publish button' };
    publishBtn.click();
    await new Promise(function(r) { setTimeout(r, 5000); });
    return { published: true, url: window.location.href };
  }`,
  profile: "{{browser_profile}}"
})
```

After publish: page redirects to `https://x.com/{handle}/status/{id}`. Success message: "Your Article has been published". Article URL: `https://x.com/{handle}/article/{id}`.

---

## Step 5 — Verify and log

Check `window.location.href` contains `/status/`. Extract article URL by replacing `/status/` with `/article/`.

