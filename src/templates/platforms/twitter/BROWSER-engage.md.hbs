## § 3 — Extract Search Tweets

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { await new Promise(r => setTimeout(r, 2000)); const tweets = Array.from(document.querySelectorAll('article[data-testid=\"tweet\"]')); const parseCount = (label) => { if (!label) return 0; const match = label.match(/^(\\d+)/); return match ? parseInt(match[1]) : 0; }; return tweets.slice(0, 10).map(t => { const user = t.querySelector('[data-testid=\"User-Name\"]'); const text = t.querySelector('[data-testid=\"tweetText\"]'); const link = t.querySelector('a[href*=\"/status/\"]'); const likeBtn = t.querySelector('[data-testid=\"like\"]'); const replyBtn = t.querySelector('[data-testid=\"reply\"]'); const retweetBtn = t.querySelector('[data-testid=\"retweet\"]'); const viewSpan = t.querySelector('a[href*=\"/analytics\"] span'); return { url: link ? 'https://x.com' + link.getAttribute('href') : '', author: user ? user.innerText.split(String.fromCharCode(10))[0] : '', handle: user ? (user.innerText.split(String.fromCharCode(10)).find(l => l.startsWith('@')) || '') : '', text: text ? text.innerText.slice(0, 200) : '', likes: parseCount(likeBtn?.getAttribute('aria-label')), replies: parseCount(replyBtn?.getAttribute('aria-label')), retweets: parseCount(retweetBtn?.getAttribute('aria-label')), views: viewSpan ? viewSpan.innerText : '0' }; }).filter(t => t.url && t.text); }"}
ENDJSON
```

## § 4 — Extract Strategic Tweets

```bash
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { await new Promise(r => setTimeout(r, 2000)); const tweets = Array.from(document.querySelectorAll('article[data-testid=\"tweet\"]')); const parseCount = (label) => { if (!label) return 0; const match = label.match(/^(\\d+)/); return match ? parseInt(match[1]) : 0; }; const now = Date.now(); return tweets.slice(0, 10).map(t => { const user = t.querySelector('[data-testid=\"User-Name\"]'); const text = t.querySelector('[data-testid=\"tweetText\"]'); const link = t.querySelector('a[href*=\"/status/\"]'); const likeBtn = t.querySelector('[data-testid=\"like\"]') || t.querySelector('[data-testid=\"unlike\"]'); const replyBtn = t.querySelector('[data-testid=\"reply\"]'); const time = t.querySelector('time')?.getAttribute('datetime'); const ageHours = time ? (now - new Date(time).getTime()) / (1000*60*60) : 999; var hasMedia = !!t.querySelector('[data-testid=\"tweetPhoto\"]') || !!t.querySelector('[data-testid=\"videoPlayer\"]') || !!t.querySelector('[data-testid=\"tweetGif\"]'); var textLen = text ? text.innerText.length : 0; return { url: link ? 'https://x.com' + link.getAttribute('href') : '', handle: user ? (user.innerText.split(String.fromCharCode(10)).find(l => l.startsWith('@')) || '') : '', text: text ? text.innerText.slice(0, 200) : '', likes: parseCount(likeBtn?.getAttribute('aria-label')), replies: parseCount(replyBtn?.getAttribute('aria-label')), ageHours: Math.round(ageHours), hasMedia: hasMedia, isMemeLikely: hasMedia && textLen < 80 }; }).filter(t => t.url && t.likes >= 100 && t.replies < 50 && t.ageHours < 48); }"}
ENDJSON
```

## § 7 — Compose / Original Tweet

```bash
# Step 1: Navigate to home
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/navigate -H 'Content-Type: application/json' -d '{"url":"https://x.com/home"}' 2>&1

# Step 2: Click compose button
exec curl -s -X POST http://localhost:3847/api/browser/{{browser_profile}}/evaluate -H 'Content-Type: application/json' -d @- <<'ENDJSON'
{"fn":"async () => { await new Promise(r => setTimeout(r, 1000)); const btn = document.querySelector('a[href=\"/compose/tweet\"]') || document.querySelector('[data-testid=\"SideNav_NewTweet_Button\"]'); if (!btn) return { error: 'compose button not found' }; btn.click(); return { clicked: true }; }"}
ENDJSON

# Step 3: Use BROWSER-core.md § 1 compose dialog pattern (clipboard paste + submit)
# 🚨 MUST use dialog-scoped selectors: [role="dialog"] [data-testid="tweetTextarea_0"]
# 🚨 NEVER use bare [data-testid="tweetTextarea_0"] — home page has TWO textareas (feed + dialog)
```

