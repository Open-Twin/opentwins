## § 3 — Extract Search Tweets

```javascript
// Use on search results pages — includes embedded 2s wait after navigate
browser.act({
  kind: "evaluate",
  fn: `() => {
    return new Promise(resolve => setTimeout(() => {
      const tweets = Array.from(document.querySelectorAll('article[data-testid="tweet"]'));
      const parseCount = (label) => {
        if (!label) return 0;
        const match = label.match(/^(\\d+)/);
        return match ? parseInt(match[1]) : 0;
      };
      resolve(tweets.slice(0, 10).map(t => {
        const user = t.querySelector('[data-testid="User-Name"]');
        const text = t.querySelector('[data-testid="tweetText"]');
        const link = t.querySelector('a[href*="/status/"]');
        const likeBtn = t.querySelector('[data-testid="like"]');
        const replyBtn = t.querySelector('[data-testid="reply"]');
        const retweetBtn = t.querySelector('[data-testid="retweet"]');
        const viewSpan = t.querySelector('a[href*="/analytics"] span');
        return {
          url: link ? 'https://x.com' + link.getAttribute('href') : '',
          author: user ? user.innerText.split('\\n')[0] : '',
          handle: user ? (user.innerText.split('\\n').find(l => l.startsWith('@')) || '') : '',
          text: text ? text.innerText.slice(0, 200) : '',
          likes: parseCount(likeBtn?.getAttribute('aria-label')),
          replies: parseCount(replyBtn?.getAttribute('aria-label')),
          retweets: parseCount(retweetBtn?.getAttribute('aria-label')),
          views: viewSpan ? viewSpan.innerText : '0'
        };
      }).filter(t => t.url && t.text));
    }, 2000));
  }`,
  profile: "{{browser_profile}}"
})
```

## § 4 — Extract Strategic Tweets

```javascript
// Use on advanced search: from:X OR from:Y min_faves:100 — includes embedded 2s wait
browser.act({
  kind: "evaluate",
  fn: `() => {
    return new Promise(resolve => setTimeout(() => {
      const tweets = Array.from(document.querySelectorAll('article[data-testid="tweet"]'));
      const parseCount = (label) => {
        if (!label) return 0;
        const match = label.match(/^(\\d+)/);
        return match ? parseInt(match[1]) : 0;
      };
      const now = Date.now();
      resolve(tweets.slice(0, 10).map(t => {
        const user = t.querySelector('[data-testid="User-Name"]');
        const text = t.querySelector('[data-testid="tweetText"]');
        const link = t.querySelector('a[href*="/status/"]');
        const likeBtn = t.querySelector('[data-testid="like"]') || t.querySelector('[data-testid="unlike"]');
        const replyBtn = t.querySelector('[data-testid="reply"]');
        const time = t.querySelector('time')?.getAttribute('datetime');
        const ageHours = time ? (now - new Date(time).getTime()) / (1000*60*60) : 999;
        var hasMedia = !!t.querySelector('[data-testid="tweetPhoto"]') || !!t.querySelector('[data-testid="videoPlayer"]') || !!t.querySelector('[data-testid="tweetGif"]');
        var textLen = text ? text.innerText.length : 0;
        return {
          url: link ? 'https://x.com' + link.getAttribute('href') : '',
          handle: user ? (user.innerText.split('\\n').find(l => l.startsWith('@')) || '') : '',
          text: text ? text.innerText.slice(0, 200) : '',
          likes: parseCount(likeBtn?.getAttribute('aria-label')),
          replies: parseCount(replyBtn?.getAttribute('aria-label')),
          ageHours: Math.round(ageHours),
          hasMedia: hasMedia,
          isMemeLikely: hasMedia && textLen < 80
        };
      }).filter(t => t.url && t.likes >= 100 && t.replies < 50 && t.ageHours < 48));
    }, 2000));
  }`,
  profile: "{{browser_profile}}"
})
```

## § 7 — Compose / Original Tweet

```javascript
browser.navigate("https://x.com/home", { profile: "{{browser_profile}}" })
browser.act({ kind: "wait", timeMs: 1000, profile: "{{browser_profile}}" })
browser.act({
  kind: "evaluate",
  fn: `() => {
    const btn = document.querySelector('a[href="/compose/tweet"]') ||
                document.querySelector('[data-testid="SideNav_NewTweet_Button"]');
    if (!btn) return { error: 'compose button not found' };
    btn.click();
    return { clicked: true };
  }`,
  profile: "{{browser_profile}}"
})
// Wait 1s → use DIALOG-SCOPED selectors (BROWSER-core.md § 1 "compose dialog" pattern):
// snapshot('[role="dialog"] [data-testid="tweetTextarea_0"]') → type
// snapshot('[role="dialog"] [data-testid="tweetButton"]') → click Post
// 🚨 NEVER use bare [data-testid="tweetTextarea_0"] — home page has TWO textareas (feed + dialog) → strict mode violation
// If click returns "Element not found" → evaluate fallback: document.querySelector('[role="dialog"] [data-testid="tweetButton"]').click()
```

